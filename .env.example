# Database
DATABASE_URL=postgresql+asyncpg://plt:plt_dev_2026@postgres:5432/plt_db
DATABASE_URL_SYNC=postgresql://plt:plt_dev_2026@postgres:5432/plt_db
DB_PASSWORD=plt_dev_2026

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=plt-files
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Security & JWT
SECRET_KEY=your-secret-key-change-in-production-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
JWT_REFRESH_EXPIRATION_DAYS=30

# API Configuration
API_V1_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:3000"]

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# External API Integrations
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
OURA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/oura/callback

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email (optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@plt.local

# Application Settings
MAX_UPLOAD_SIZE_MB=100
REQUEST_TIMEOUT_SECONDS=30
DB_ECHO=false
